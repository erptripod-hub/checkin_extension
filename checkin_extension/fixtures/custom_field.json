[
  {
    "name": "Employee Checkin-project",
    "doctype": "Custom Field",
    "dt": "Employee Checkin",
    "module": "Checkin Extension",
    "fieldname": "project",
    "fieldtype": "Link",
    "options": "Project",
    "label": "Project",
    "insert_after": "log_type",
    "in_list_view": 1,
    "in_standard_filter": 1
  },
  {
    "name": "Employee Checkin-section_gps",
    "doctype": "Custom Field",
    "dt": "Employee Checkin",
    "module": "Checkin Extension",
    "fieldname": "section_gps",
    "fieldtype": "Section Break",
    "label": "GPS & Photo",
    "insert_after": "skip_auto_attendance",
    "collapsible": 0
  },
  {
    "name": "Employee Checkin-latitude",
    "doctype": "Custom Field",
    "dt": "Employee Checkin",
    "module": "Checkin Extension",
    "fieldname": "latitude",
    "fieldtype": "Float",
    "label": "Latitude",
    "insert_after": "section_gps",
    "precision": "8",
    "read_only": 1
  },
  {
    "name": "Employee Checkin-longitude",
    "doctype": "Custom Field",
    "dt": "Employee Checkin",
    "module": "Checkin Extension",
    "fieldname": "longitude",
    "fieldtype": "Float",
    "label": "Longitude",
    "insert_after": "latitude",
    "precision": "8",
    "read_only": 1
  },
  {
    "name": "Employee Checkin-gps_location",
    "doctype": "Custom Field",
    "dt": "Employee Checkin",
    "module": "Checkin Extension",
    "fieldname": "gps_location",
    "fieldtype": "Data",
    "label": "GPS Location",
    "insert_after": "longitude",
    "read_only": 1,
    "description": "Click to open in Google Maps"
  },
  {
    "name": "Employee Checkin-column_break_gps",
    "doctype": "Custom Field",
    "dt": "Employee Checkin",
    "module": "Checkin Extension",
    "fieldname": "column_break_gps",
    "fieldtype": "Column Break",
    "insert_after": "gps_location"
  },
  {
    "name": "Employee Checkin-checkin_photo",
    "doctype": "Custom Field",
    "dt": "Employee Checkin",
    "module": "Checkin Extension",
    "fieldname": "checkin_photo",
    "fieldtype": "Attach Image",
    "label": "Photo",
    "insert_after": "column_break_gps"
  }
]
